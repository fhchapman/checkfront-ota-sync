# Checkfront API (Manage > Integrations > API in Checkfront)
# Use API key + API secret for request signing, or token if provided
CHECKFRONT_HOST=your-company.checkfront.com
CHECKFRONT_API_KEY=your_api_key
CHECKFRONT_API_SECRET=your_api_secret

# Viator – from Viator Connectivity details (Reservation system: Checkfront)
# Paste the "API key" from Viator's connectivity page here
VIATOR_API_KEY=your_viator_api_key
# API supplier ID from the same page (e.g. 5034073)
VIATOR_SUPPLIER_ID=
VIATOR_API_BASE_URL=https://api.viator.com
# Optional: if Viator sends callbacks to this sync service, set base URL where this app is hosted
VIATOR_CALLBACK_BASE_URL=https://your-server.com

# Get Your Guide API (optional — add when you have GYG API access; leave placeholder for now)
GETYOURGUIDE_API_KEY=
GETYOURGUIDE_API_BASE_URL=https://api.getyourguide.com

# Sync behavior
# Checkfront status code to set when OTA cancels (default: VOID)
CHECKFRONT_CANCELLED_STATUS=VOID
# How often to poll OTA APIs for updates (seconds); only used in polling mode
SYNC_POLL_INTERVAL=300
